{
  "name": "bilive-coyote",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/main.ts",
    "start": "bun run src/main.ts",
    "check": "tsc --noEmit",
    "lint": "biome check --write",
    "lint:ci": "biome ci",
    "build": "bun run scripts/build.ts",
    "build:linux-x64": "bun run scripts/build.ts bun-linux-x64-baseline",
    "build:linux-arm64": "bun run scripts/build.ts bun-linux-arm64",
    "build:windows-x64": "bun run scripts/build.ts bun-windows-x64-baseline",
    "build:windows-arm64": "bun run scripts/build.ts bun-windows-arm64",
    "build:darwin-x64": "bun run scripts/build.ts bun-darwin-x64",
    "build:darwin-arm64": "bun run scripts/build.ts bun-darwin-arm64",
    "build:all": "bun run scripts/build.ts bun-linux-x64-baseline bun-linux-arm64 bun-windows-x64-baseline bun-windows-arm64 bun-darwin-x64 bun-darwin-arm64"
  },
  "dependencies": {
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@types/bun": "^1.3.13",
    "@types/qrcode": "^1.5.5",
    "typescript": "^6.0.3"
  }
}
